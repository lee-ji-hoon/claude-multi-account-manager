{
  "description": "Claude Code 계정 관리 Hook - 세션 시작 시 계정 등록, 메시지 입력 시 만료 임박 토큰 갱신",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/prompt-submit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
